{
    "runs": 3,
    "timeout_seconds": 600,
    "retry_count": 1,
    "models": [
        {
            "name": "opus-direct",
            "env": {
                "ANTHROPIC_API_KEY": "sk-ant-xxx",
                "ANTHROPIC_BASE_URL": "https://api.anthropic.com"
            },
            "model": "claude-opus-4-8-20250514",
            "thinking": { "type": "enabled", "budget_tokens": 16000 }
        },
        {
            "name": "sonnet-openrouter",
            "env": {
                "ANTHROPIC_API_KEY": "sk-or-xxx",
                "ANTHROPIC_BASE_URL": "https://openrouter.ai/api/v1/anthropic"
            },
            "model": "anthropic/claude-sonnet-5",
            "thinking": { "type": "enabled", "budget_tokens": 16000 }
        }
    ],
    "sandbox": {
        "enabled": false,
        "image": "code-bench-sandbox:latest",
        "build_on_start": true
    },
    "prompts": ["prompts/pi-digits"],
    "template_dir": null,
    "feishu_folder_token": ""
}
